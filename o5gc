#!/bin/bash
# open5Gcube command line entry point, delegating to the scripts in scripts/:
#
#   o5gc docker build ...        ->  scripts/docker.sh build ...
#   o5gc stack up|down|... ...   ->  scripts/stack.sh up|down|... ...

set -euo pipefail

BASE_DIR=$(dirname "$(realpath "$0")")
export BASE_DIR

case "${1:-}" in
    docker|stack)
        exec "${BASE_DIR}/scripts/$1.sh" "${@:2}" ;;
    *)
        echo "Usage: $(basename "$0") docker|stack ..." >&2
        exit 1 ;;
esac
